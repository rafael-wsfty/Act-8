using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Practica7
{
    internal class Operaciones
    {   
        public void IncrementoPorValor(int n1)
        {
            n1 = n1 + 10;
            Console.WriteLine("Dentro de IncrementoPorValor, n1 vale: " + n1);
        }

        public void IncrementoPorReferencia(ref int n1)
        {
            n1 = n1 + 10;
            Console.WriteLine("Dentro de IncrementoPorReferencia, n1 vale: " + n1);
        }
    }
}
